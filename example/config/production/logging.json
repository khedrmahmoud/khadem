{
  "default": "stack",
  "channels": {
    "stack": {
      "driver": "stack",
      "channels": ["daily"]
    },
    "daily": {
      "driver": "daily",
      "path": "storage/logs/khadem.log",
      "level": "info",
      "days": 14
    },
    "console": {
      "driver": "console",
      "level": "error",
      "colorize": false
    }
  }
}
